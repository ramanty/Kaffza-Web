# Kaffza Monorepo Environment Variables Example
NODE_ENV=development
API_PORT=4000
APP_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/kaffza_db?schema=public"
DATABASE_NAME=kaffza_db
DATABASE_USER=kaffza_user
DATABASE_PASSWORD=change_me_in_production
JWT_SECRET="YOUR_SUPER_SECRET_JWT_KEY_HERE_MINIMUM_32_CHARS"
JWT_EXPIRATION="15m"
JWT_REFRESH_SECRET="different-min-32-char-secret"
JWT_REFRESH_EXPIRATION="7d"
REDIS_URL="redis://localhost:6379"
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
EXPO_PUBLIC_API_URL="http://localhost:4000/api/v1"

# Thawani Pay (Sandbox/UAT)
THAWANI_BASE_URL=https://uatcheckout.thawani.om/api/v1
THAWANI_REDIRECT_BASE=https://uatcheckout.thawani.om/pay/
THAWANI_API_URL=https://uatcheckout.thawani.om/api/v1
THAWANI_SECRET_KEY=YOUR_THAWANI_SECRET_API_KEY
THAWANI_API_KEY=YOUR_THAWANI_SECRET_API_KEY
THAWANI_PUBLISHABLE_KEY=YOUR_THAWANI_PUBLISHABLE_KEY
THAWANI_SUCCESS_URL=http://localhost:3000/pay/success
THAWANI_CANCEL_URL=http://localhost:3000/pay/cancel
THAWANI_WEBHOOK_SECRET=YOUR_THAWANI_WEBHOOK_SECRET

# SMS
SMS_PROVIDER=console
SMS_API_KEY=
SMS_SENDER_ID=Kaffza

# MinIO / S3
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_URL=http://localhost:9000
S3_ACCESS_KEY=kaffza_minio
S3_SECRET_KEY=kaffza_minio_secret
S3_BUCKET=kaffza-images
S3_REGION=us-east-1

# Deployment
DOMAIN=kaffza.me
