graph TB
    subgraph "🌍 CDN Layer"
        CDN["Cloudflare CDN<br/>Static Assets + DDoS Protection"]
    end

    subgraph "🔀 Load Balancer"
        LB["Nginx Load Balancer<br/>SSL Termination + Rate Limiting"]
    end

    subgraph "🖥️ Application Servers"
        direction LR
        APP1["NestJS Instance 1<br/>API Server"]
        APP2["NestJS Instance 2<br/>API Server"]
    end

    subgraph "🌐 Web Server"
        NEXT["Next.js Server<br/>SSR + Static Generation"]
    end

    subgraph "💾 Database Cluster"
        direction LR
        PG_PRIMARY["PostgreSQL Primary<br/>Read + Write"]
        PG_REPLICA["PostgreSQL Replica<br/>Read Only"]
    end

    subgraph "⚡ Cache Layer"
        REDIS_MAIN["Redis Primary<br/>Sessions + OTP + Cache"]
    end

    subgraph "📁 Storage"
        S3["S3-Compatible Storage<br/>Product Images + Files"]
    end

    subgraph "⏰ Background Jobs"
        WORKER["Worker Process<br/>Escrow Release Cron<br/>Email Queue<br/>SMS Queue"]
    end

    subgraph "📊 Monitoring"
        direction LR
        LOGS["Logging<br/>(Winston + ELK)"]
        METRICS["Metrics<br/>(Prometheus + Grafana)"]
        ALERTS["Alerts<br/>(Slack/Email)"]
    end

    CDN --> LB
    LB --> NEXT
    LB --> APP1
    LB --> APP2

    APP1 --> PG_PRIMARY
    APP2 --> PG_PRIMARY
    APP1 --> PG_REPLICA
    APP2 --> PG_REPLICA
    APP1 --> REDIS_MAIN
    APP2 --> REDIS_MAIN
    APP1 --> S3
    APP2 --> S3

    NEXT --> APP1
    NEXT --> APP2

    WORKER --> PG_PRIMARY
    WORKER --> REDIS_MAIN

    PG_PRIMARY --> PG_REPLICA

    APP1 --> LOGS
    APP2 --> LOGS
    LOGS --> METRICS
    METRICS --> ALERTS

    classDef cdn fill:#FF9800,stroke:#E65100,color:#fff,stroke-width:2px
    classDef lb fill:#2196F3,stroke:#0D47A1,color:#fff,stroke-width:2px
    classDef app fill:#4CAF50,stroke:#1B5E20,color:#fff,stroke-width:2px
    classDef db fill:#9C27B0,stroke:#4A148C,color:#fff,stroke-width:2px
    classDef cache fill:#F44336,stroke:#B71C1C,color:#fff,stroke-width:2px
    classDef storage fill:#607D8B,stroke:#263238,color:#fff,stroke-width:2px
    classDef worker fill:#795548,stroke:#3E2723,color:#fff,stroke-width:2px
    classDef monitor fill:#009688,stroke:#004D40,color:#fff,stroke-width:2px

    class CDN cdn
    class LB lb
    class APP1,APP2,NEXT app
    class PG_PRIMARY,PG_REPLICA db
    class REDIS_MAIN cache
    class S3 storage
    class WORKER worker
    class LOGS,METRICS,ALERTS monitor
