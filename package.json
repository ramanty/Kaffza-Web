{
  "name": "kaffza",
  "version": "0.1.0",
  "private": true,
  "description": "Kaffza (قفزة) — أول منصة تجارة إلكترونية عُمانية SaaS",
  "author": "جوهرة الشهباء الحديثة ش.م.م",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  },
  "packageManager": "pnpm@8.x.x",
  "scripts": {
    "dev": "turbo run dev",
    "dev:api": "turbo run dev --filter=@kaffza/api",
    "dev:web": "turbo run dev --filter=@kaffza/web",
    "dev:mobile": "turbo run dev --filter=@kaffza/mobile",
    "build": "turbo run build",
    "build:api": "turbo run build --filter=@kaffza/api",
    "build:web": "turbo run build --filter=@kaffza/web",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:migrate": "turbo run db:migrate --filter=@kaffza/api",
    "db:seed": "turbo run db:seed --filter=@kaffza/api",
    "clean": "turbo run clean && rm -rf node_modules",
    "ci": "pnpm build && pnpm --filter @kaffza/api test -- --runInBand"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "prettier": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "eslint": "^9.23.0",
    "@typescript-eslint/parser": "^8.29.0",
    "@typescript-eslint/eslint-plugin": "^8.29.0",
    "eslint-config-next": "^15.1.0"
  }
}
