graph TB
    subgraph "🌐 العملاء / Clients"
        direction LR
        WEB["🖥️ Next.js Web App<br/>(Merchant Dashboard + Admin + Storefront)"]
        MOB["📱 React Native Mobile App<br/>(iOS + Android)"]
    end

    subgraph "☁️ طبقة الوسيط / Middleware Layer"
        NGINX["⚡ Nginx Reverse Proxy<br/>+ SSL Termination"]
        RATE["🛡️ Rate Limiter<br/>+ CORS"]
    end

    subgraph "🔧 الخادم الخلفي / Backend - NestJS Modular Monolith"
        direction TB
        GW["🚪 API Gateway<br/>(REST + GraphQL)"]
        
        subgraph "📦 وحدات الأعمال / Business Modules"
            direction LR
            AUTH["🔐 Auth Module<br/>JWT + OTP"]
            STORE["🏪 Store Module<br/>Multi-tenant"]
            PROD["📦 Product Module<br/>Catalog + Inventory"]
            ORD["📋 Order Module<br/>Lifecycle Management"]
            PAY["💳 Payment Module<br/>Thawani + Escrow"]
            SHIP["🚚 Shipping Module<br/>Jeena Integration"]
            WALL["💰 Wallet Module<br/>Balance + Withdrawals"]
            DISP["⚖️ Dispute Module<br/>Resolution System"]
            ADMIN["👑 Admin Module<br/>Platform Management"]
        end

        CRON["⏰ Cron Jobs<br/>(Escrow Release + Cleanup)"]
    end

    subgraph "💾 طبقة البيانات / Data Layer"
        direction LR
        PG["🐘 PostgreSQL<br/>Primary Database"]
        REDIS["⚡ Redis<br/>Cache + Sessions + OTP"]
        S3["📁 Object Storage<br/>(S3-compatible)<br/>Images + Files"]
    end

    subgraph "🔌 الخدمات الخارجية / External Services"
        direction LR
        THAW["💳 Thawani Pay<br/>Payment Gateway"]
        JEENA["🚚 جيناكم<br/>Shipping Provider"]
        SMS["📲 SMS Gateway<br/>OTP Delivery"]
        EMAIL["📧 Email Service<br/>Notifications"]
    end

    WEB -->|"HTTPS"| NGINX
    MOB -->|"HTTPS"| NGINX
    NGINX --> RATE
    RATE --> GW

    GW --> AUTH
    GW --> STORE
    GW --> PROD
    GW --> ORD
    GW --> PAY
    GW --> SHIP
    GW --> WALL
    GW --> DISP
    GW --> ADMIN

    AUTH --> PG
    STORE --> PG
    PROD --> PG
    ORD --> PG
    PAY --> PG
    SHIP --> PG
    WALL --> PG
    DISP --> PG
    ADMIN --> PG

    AUTH --> REDIS
    GW --> REDIS

    PROD --> S3

    PAY --> THAW
    SHIP --> JEENA
    AUTH --> SMS
    ORD --> EMAIL

    CRON --> PAY
    CRON --> WALL

    classDef client fill:#4A90D9,stroke:#2C5F8A,color:#fff,stroke-width:2px
    classDef middleware fill:#F5A623,stroke:#C47D1A,color:#fff,stroke-width:2px
    classDef backend fill:#7B68EE,stroke:#5A4DB5,color:#fff,stroke-width:2px
    classDef module fill:#50C878,stroke:#3A9659,color:#fff,stroke-width:2px
    classDef data fill:#FF6B6B,stroke:#CC5555,color:#fff,stroke-width:2px
    classDef external fill:#95A5A6,stroke:#7F8C8D,color:#fff,stroke-width:2px

    class WEB,MOB client
    class NGINX,RATE middleware
    class GW,CRON backend
    class AUTH,STORE,PROD,ORD,PAY,SHIP,WALL,DISP,ADMIN module
    class PG,REDIS,S3 data
    class THAW,JEENA,SMS,EMAIL external
