NODE_ENV=production
API_PORT=4000
APP_URL=https://kaffza.me
CORS_ORIGIN=https://kaffza.me

DATABASE_URL="postgresql://kaffza_user:change_me_in_production@postgres:5432/kaffza_db?schema=public"
DATABASE_NAME=kaffza_db
DATABASE_USER=kaffza_user
DATABASE_PASSWORD=change_me_in_production

JWT_SECRET="min-32-char-secret-here"
JWT_EXPIRATION="15m"
JWT_REFRESH_SECRET="different-min-32-char-secret"
JWT_REFRESH_EXPIRATION="7d"

REDIS_URL="redis://redis:6379"
NEXT_PUBLIC_API_URL="https://kaffza.me/api/v1"
NEXT_PUBLIC_APP_URL="https://kaffza.me"
EXPO_PUBLIC_API_URL="https://kaffza.me/api/v1"

THAWANI_API_URL=https://api.thawani.om/api/v1
THAWANI_API_KEY=
THAWANI_PUBLISHABLE_KEY=
THAWANI_WEBHOOK_SECRET=
THAWANI_SUCCESS_URL=https://kaffza.me/pay/success
THAWANI_CANCEL_URL=https://kaffza.me/pay/cancel

SMS_PROVIDER=console
SMS_API_KEY=
SMS_SENDER_ID=Kaffza

S3_ENDPOINT=http://minio:9000
S3_PUBLIC_URL=https://kaffza.me/files
S3_ACCESS_KEY=kaffza_minio
S3_SECRET_KEY=kaffza_minio_secret
S3_BUCKET=kaffza-images
S3_REGION=us-east-1

DOMAIN=kaffza.me
